{
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "exclude": [
    "**/console/bin",
    "dist",
    "**/dist",
    "**/**/dist",
    "**/node_modules",
    "node_modules",
    "**/node_modules/*",
    "**/public/**",
    "**/storage/**",
    "eslint.config.js",
    "jest.config.ts",
    "arquebus.config.js",
    "**/coverage/**"
  ],
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  }
}
